# Copy to .env.testing (gitignored) and fill in local values.
# Used for artisan commands with --env=testing and documented PG test runs.
# PHPUnit reads OS env / phpunit.xml; export these when running PG tests.

APP_NAME="منصة كفاءات"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Riyadh

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kafaat_testing
DB_USERNAME=kafaat
DB_PASSWORD=

# Optional URL form (overrides discrete vars when set):
# DB_URL=pgsql://kafaat:YOUR_PASSWORD@127.0.0.1:5432/kafaat_testing

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

IDENTITY_LOOKUP_KEY=base64:dGVzdC1pZGVudGl0eS1sb29rdXAta2V5LTMyYnl0ZXM=
PRIVATE_DOCUMENTS_DISK=private_documents
CV_MAX_SIZE_KB=10240
