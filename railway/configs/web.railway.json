{
  "$schema": "https://railway.com/railway.schema.json",
  "deploy": {
    "preDeployCommand": ["bash railway/predeploy.sh"],
    "startCommand": "bash railway/start.sh",
    "healthcheckPath": "/up",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 60,
    "drainingSeconds": 15
  }
}
