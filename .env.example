# ── في الإنتاج: APP_ENV=production و APP_DEBUG=false إلزاماً ──
APP_NAME="منصة كفاءات"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# No trailing slash. Production: https://your-public-hostname (must match TRUSTED_HOSTS).
APP_URL=http://localhost

APP_TIMEZONE=Asia/Riyadh

# Production HTTPS (FORCE_HTTPS defaults to true when APP_ENV=production)
FORCE_HTTPS=false
# Comma-separated public hostnames only (required in production), e.g. kafaat.example.com
TRUSTED_HOSTS=
# Proxy trust: "*" for Railway edge (default). Prefer comma-separated CIDRs if the app is reachable without the edge.
TRUSTED_PROXIES=*
SECURITY_HSTS_ENABLED=false
SECURITY_CSP_REPORT_ONLY=false

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Local: single file. Production (Railway): LOG_STACK=stderr so logs reach platform drains.
# Optional structured drain: LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
LOG_STACK=single
# LOG_STACK=stderr
# LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
LOG_DEPRECATIONS_CHANNEL=null
# Production: warning or error
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kafaat
DB_USERNAME=
DB_PASSWORD=
# PHPUnit defaults to SQLite in phpunit.xml; for Postgres tests see
# .env.testing.example and docs/testing/postgresql-test-environment.md

SESSION_DRIVER=file
SESSION_LIFETIME=120
# Production: set SESSION_ENCRYPT=true (defaults to true when APP_ENV=production).
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production (HTTPS): set SESSION_SECURE_COOKIE=true (defaults to true when APP_ENV=production).
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Same-origin by default. Only set when a cross-origin client is introduced.
# CORS_ALLOWED_ORIGINS=https://app.example.com
# CORS_SUPPORTS_CREDENTIALS=false

# مفتاح HMAC مستقل للبحث عن تكرار رقم الهوية (لا يُخزَّن في Git — استخدم secret manager)
IDENTITY_LOOKUP_KEY=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Durable storage (Railway) ─────────────────────────────────────────────────
# Public media (news images, Filament uploads). Choose ONE:
#   A) Volume on web service mount /app/storage/app/public + PUBLIC_STORAGE_PERSISTENT=1
#   B) PUBLIC_DISK_DRIVER=s3 with AWS_* / AWS_PUBLIC_BUCKET
# See docs/deployment/public-media-storage.md
PUBLIC_DISK_DRIVER=local
# PUBLIC_DISK_ROOT=
# PUBLIC_DISK_URL=
# PUBLIC_STORAGE_PERSISTENT=
# AWS_PUBLIC_BUCKET=

# Private CVs / privacy export ZIPs (NEVER the public disk).
# Local default: private_documents → storage/app/private-documents
# Railway volume (web + any service that writes CVs/exports): mount
#   /app/storage/app/private-documents
# Or set PRIVATE_DOCUMENTS_DISK=s3 and AWS_BUCKET (private bucket).
QUEUE_CONNECTION=database
# Railway: set RAILWAY_START_MODE=worker on a dedicated service (see railway/run-worker.sh)

# Local: file is fine. Production: use database or redis (file fails production health checks;
# rate limiters need a shared atomic store across web replicas).
CACHE_STORE=file
# Optional shared-prefix when using Redis with multiple apps:
# CACHE_PREFIX=kafaat-cache-

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — production MUST NOT use log (OTP/notifications will never send).
# Local only: MAIL_MAILER=log
# Production: resend (below) or smtp with MAIL_HOST / MAIL_PORT / MAIL_USERNAME / MAIL_PASSWORD
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="noreply@kafaat.org.sa"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_MAILER=smtp
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_SCHEME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Private CV storage (Phase 4) ──────────────────────────────────────────────
PRIVATE_DOCUMENTS_DISK=private_documents
CV_MAX_SIZE_KB=10240

# ── Railway service roles (set per service in Railway UI; do not put secrets here) ──
# RAILWAY_START_MODE=web|worker|scheduler
# Web healthcheck: GET /up (wired in railway.json / railway.toml)

# Personal data export ZIP availability (days) — required in production
PRIVACY_EXPORT_TTL_DAYS=7

# Retention engine (preview freshness, batching, locks)
PRIVACY_RETENTION_PREVIEW_FRESHNESS_HOURS=24
PRIVACY_RETENTION_BATCH_SIZE=100
PRIVACY_RETENTION_LOCK_TTL=3600
PRIVACY_RETENTION_OTP_GRACE_DAYS=1

# Set these in Railway environment variables — do NOT commit real values.
# Password rules: ≥14 chars, uppercase, lowercase, digit, special char.
ADMIN_NAME="System Admin"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Optional seeding flags (see database/seeders/DatabaseSeeder.php) ───────────
# Default `php artisan db:seed` only runs roles + AdminUserSeeder (no news wipe, no demo data).

# SEED_DEMO_DATA=true — seeds staff users, paths, programs, partners, volunteer ops, registrations, certs, team.
SEED_DEMO_DATA=false

# SEED_NEWS=true — runs NewsSeeder (truncates and repopulates `news`; use only when intentional).
SEED_NEWS=false

# RESET_DEMO_DATA=true — runs CleanDemoDataSeeder (destructive demo cleanup; preserves ADMIN_EMAIL user).
RESET_DEMO_DATA=false

